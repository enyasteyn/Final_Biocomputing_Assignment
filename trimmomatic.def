Bootstrap: docker
From: ubuntu:22.04

%labels
MAINTAINER enyasteyn
WHATAMI chip_student

%environment
export PATH=$PATH:/usr/local/bin
export LANG=C.UTF-8
export LC_ALL=C.UTF-8


%post
apt-get -y update
apt-get install -y build-essential wget default-jre unzip

cd /opt
wget http://www.usadellab.org/cms/uploads/supplementary/Trimmomatic/Trimmomatic-0.39.zip
unzip Trimmomatic-0.39.zip
rm Trimmomatic-0.39.zip

printf '#!/bin/bash\njava -jar /opt/Trimmomatic-0.39/trimmomatic-0.39.jar "$@"\n' > /usr/local/bin/trimmomatic
chmod +x /usr/local/bin/trimmomatic

%runscript
exec trimmomatic "$@"
